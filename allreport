<!DOCTYPE html>
<html>
<head>
<title>All Reports</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>

body{
    margin:0;
    padding:20px;
    background:#f2f2f2;
    font-family:Arial;
}

.container{
    max-width:600px;
    margin:auto;
    background:white;
    padding:20px;
    border-radius:12px;
    box-shadow:0 0 10px #ccc;
}

h2{
    text-align:center;
}

.report{
    background:#eeeeee;
    padding:15px;
    margin:10px 0;
    border-radius:8px;
}

button{
    width:100%;
    padding:14px;
    background:#1976d2;
    color:white;
    border:none;
    border-radius:8px;
    font-size:18px;
}

</style>

</head>

<body>

<div class="container">

<h2>BuildTrack Pro</h2>

<div class="report">
Customer Report
</div>

<div class="report">
Worker Report
</div>

<div class="report">
Material Report
</div>

<div class="report">
Billing Report
</div>

<br>

<button onclick="createPDF()">
Download All Report PDF
</button>

</div>


<script>

function createPDF(){

const { jsPDF } = window.jspdf;

let pdf = new jsPDF();

pdf.setFontSize(18);
pdf.text("BuildTrack Pro",20,20);

pdf.setFontSize(14);

pdf.text("All Reports",20,35);

pdf.text("1. Customer Report",20,55);

pdf.text("2. Worker Report",20,70);

pdf.text("3. Material Report",20,85);

pdf.text("4. Billing Report",20,100);


pdf.save("BuildTrack_All_Report.pdf");

}

</script>


</body>
</html>