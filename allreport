<!DOCTYPE html>
<html>
<head>

<title>All Report</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>

body{
    margin:0;
    padding:20px;
    background:#f2f2f2;
    font-family:Arial;
}

.container{
    max-width:600px;
    margin:auto;
    background:white;
    padding:20px;
    border-radius:12px;
    box-shadow:0 0 10px #aaa;
}

select,button{
    width:100%;
    padding:12px;
    margin-top:10px;
    font-size:16px;
}

button{
    background:#1976d2;
    color:white;
    border:none;
    border-radius:8px;
}

.report{
    margin-top:20px;
}

.report p{
    background:#eee;
    padding:10px;
    border-radius:8px;
}

</style>

</head>


<body>


<div class="container">


<h2>📋 All Work Report</h2>


<select id="category">

<option value="All">All</option>
<option value="Civil">Civil</option>
<option value="Electrical">Electrical</option>
<option value="Plumbing">Plumbing</option>
<option value="Tiles">Tiles</option>
<option value="Other">Other</option>

</select>


<button onclick="showReport()">View Report</button>


<button onclick="downloadPDF()">Download PDF</button>


<div id="report" class="report"></div>


</div>



<script>


let flats=[
"101","102","201","202",
"301","302","401","402",
"501","502","601","602",
"701","702"
];


let reportData=[];



function showReport(){


let type =
document.getElementById("category").value;


let box =
document.getElementById("report");


box.innerHTML="";

reportData=[];


flats.forEach(function(flat){


let data =
JSON.parse(localStorage.getItem(flat)) || [];


data.forEach(function(item){


if(type=="All" || item.type==type){


reportData.push(
"Flat No : "+flat+
"\nWork : "+item.type+
"\nDetail : "+item.note
);


box.innerHTML +=

"<p>"+
"<b>Flat No : "+flat+"</b><br>"+
"Work : "+item.type+
"<br>Detail : "+item.note+
"</p>";


}


});


});



if(reportData.length==0){

box.innerHTML="<p>No Work Found</p>";

reportData.push("No Work Found");

}


}



function downloadPDF(){


const {jsPDF}=window.jspdf;


let pdf=new jsPDF();


pdf.text("BuildTrack Pro Work Report",10,15);


let y=30;


reportData.forEach(function(t){


let lines=pdf.splitTextToSize(t,180);


pdf.text(lines,10,y);


y=y+(lines.length*8);


if(y>280){

pdf.addPage();

y=20;

}


});


pdf.save("All_Report.pdf");


}


</script>


</body>
</html>